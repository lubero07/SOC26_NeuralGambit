#pragma once
#include "chess.hpp"
#include <algorithm>

using namespace chess;

// Simple values: Pawn=100, Knight=300, Bishop=300, Rook=500, Queen=900
const int VALUES[] = {100, 300, 300, 500, 900, 0};

// Count material on the board
inline int evaluate(Board& board) {
    int score = 0;
    
    // An array of the exact PieceTypes the library uses
    PieceType types[] = { PieceType::PAWN, PieceType::KNIGHT, PieceType::BISHOP, PieceType::ROOK, PieceType::QUEEN };
    
    // Loop through the 5 scoring pieces (0 to 4)
    for (int i = 0; i < 5; ++i) {
        int white = board.pieces(types[i], Color::WHITE).count();
        int black = board.pieces(types[i], Color::BLACK).count();
        
        if (board.sideToMove() == Color::WHITE) {
            score += (white - black) * VALUES[i];
        } else {
            score += (black - white) * VALUES[i];
        }
    }
    return score;
}

// Alpha-beta search function
inline int negamax(Board& board, int depth, int alpha, int beta, Move& best_move) {
    if (depth == 0) {
        return evaluate(board);
    }
    
    Movelist moves;
    movegen::legalmoves(moves, board);
    
    // Checkmate or Stalemate check
    if (moves.size() == 0) {
        if (board.inCheck()) return -100000; // I lost
        return 0; // Draw
    }
    
    int max_score = -1000000;
    Move local_best = moves[0];
    
    for (int i = 0; i < moves.size(); i++) {
        board.makeMove(moves[i]);
        int score = -negamax(board, depth - 1, -beta, -alpha, best_move);
        board.unmakeMove(moves[i]);
        
        if (score > max_score) {
            max_score = score;
            local_best = moves[i];
        }
        
        alpha = std::max(alpha, score);
        if (alpha >= beta) {
            break; // Skip searching useless moves
        }
    }
    
    best_move = local_best;
    return max_score;
}
